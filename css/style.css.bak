* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    color: white;
    text-align: center;
    overflow-x: hidden;
    cursor: auto; /* cursor visible normal */
}

/* NAVBAR */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: rgba(50, 0, 100, 0.7);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    z-index: 1000;
    padding: 12px 0;
    box-shadow: 0 0 15px rgba(160, 0, 255, 0.4);
}

.navbar ul {
    list-style: none;
    display: flex;
    gap: 25px;
}

.navbar ul li a {
    color: #e0aaff;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.3s ease, text-shadow 0.3s ease;
}

.navbar ul li a:hover {
    color: #ffffff;
    text-shadow: 0 0 8px #c77dff, 0 0 12px #9d4edd;
}

/* Desplazamiento suave */
html {
    scroll-behavior: smooth;
}

/* Ajuste para que no tape el navbar */
header, section {
    padding-top: 70px;
}

header {
    padding: 50px 20px;
}

.title {
    font-size: 2.5em;
    font-weight: bold;
    animation: glow 2s ease-in-out infinite alternate;
}

.subtitle {
    font-size: 1.2em;
    margin-top: 10px;
    color: #d0b3ff;
}

section {
    padding: 40px 20px;
    max-width: 800px;
    margin: auto;
    background: rgba(20, 0, 40, 0.6);
    border-radius: 15px;
    margin-top: 30px;
    box-shadow: 0 0 20px rgba(160, 0, 255, 0.3);
    transition: transform 0.3s ease;
}

section:hover {
    transform: scale(1.02);
}

h2 {
    color: #e0aaff;
    margin-bottom: 15px;
}

ul {
    list-style: none;
}

#background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: black;
}

@keyframes glow {
    from {
        text-shadow: 0 0 10px #a855f7, 0 0 20px #c77dff, 0 0 30px #9d4edd;
    }
    to {
        text-shadow: 0 0 20px #c77dff, 0 0 40px #e0aaff, 0 0 60px #9d4edd;
    }

    /* Estilos para enlaces de contacto */
#contact a {
    color: #e0aaff;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.3s ease, text-shadow 0.3s ease;
}

#contact a:hover {
    color: #ffffff;
    text-shadow: 0 0 8px #c77dff, 0 0 12px #9d4edd;
}


/* =========================================== */
/* ESTILOS ESPECÍFICOS PARA PÁGINA DE PROYECTOS */
/* =========================================== */

/* Contenedor principal de proyectos */
.projects-container {
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-top: 20px;
}

/* Tarjetas de proyecto */
.project-card {
    background: rgba(30, 0, 60, 0.7);
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 0 20px rgba(160, 0, 255, 0.3);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(200, 100, 255, 0.2);
}

.project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 0 30px rgba(200, 100, 255, 0.5);
}

/* Títulos de proyecto */
.project-title {
    color: #e0aaff;
    font-size: 1.8em;
    margin-bottom: 15px;
    text-shadow: 0 0 10px rgba(200, 100, 255, 0.5);
}

/* Tecnologías (tags) */
.project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 15px 0;
}

.tech-tag {
    background: rgba(160, 0, 255, 0.3);
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.9em;
    border: 1px solid rgba(200, 100, 255, 0.4);
}

/* Descripción de proyectos */
.project-description {
    line-height: 1.6;
    margin-bottom: 20px;
}

/* Enlaces de proyecto */
.project-link {
    display: inline-block;
    background: linear-gradient(45deg, #9d4edd, #c77dff);
    color: white;
    padding: 10px 25px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 0 15px rgba(160, 0, 255, 0.4);
}

.project-link:hover {
    transform: scale(1.05);
    box-shadow: 0 0 25px rgba(200, 100, 255, 0.7);
}

/* Enlace para volver */
.back-link {
    display: inline-block;
    margin-top: 40px;
    color: #e0aaff;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.3s;
}

.back-link:hover {
    color: white;
    text-shadow: 0 0 10px #c77dff;
}

/* =========================================== */
/* ESTILOS ESPECÍFICOS PARA DETALLE DE PROYECTO */
/* =========================================== */

/* Contenedor de detalle */
.project-detail {
    text-align: left;
    max-width: 900px;
    margin: 40px auto;
    padding: 30px;
    background: rgba(30, 0, 60, 0.7);
    border-radius: 15px;
    box-shadow: 0 0 25px rgba(160, 0, 255, 0.4);
}

/* Imagen de proyecto */
.project-image {
    width: 100%;
    max-width: 800px;
    margin: 20px auto;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(200, 100, 255, 0.3);
}

.project-image img {
    width: 100%;
    height: auto;
    display: block;
}

/* Listas de características */
.features-list {
    list-style-type: none;
    padding-left: 20px;
}

.features-list li {
    margin: 10px 0;
    padding-left: 25px;
    position: relative;
}

.features-list li:before {
    content: "✓";
    color: #c77dff;
    position: absolute;
    left: 0;
    font-weight: bold;
}

/* Badges de tecnología */
.tech-badge {
    display: inline-block;
    background: rgba(160, 0, 255, 0.3);
    padding: 8px 18px;
    margin: 5px;
    border-radius: 20px;
    border: 1px solid rgba(200, 100, 255, 0.4);
}

/* Navegación entre proyectos */
.nav-links {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid rgba(200, 100, 255, 0.3);
}

.nav-link {
    color: #e0aaff;
    text-decoration: none;
    font-weight: bold;
    padding: 10px 20px;
    border-radius: 8px;
    background: rgba(160, 0, 255, 0.2);
    transition: all 0.3s;
}

.nav-link:hover {
    background: rgba(200, 100, 255, 0.4);
    transform: translateY(-3px);
}

/* =========================================== */
/* ESTILOS ESPECÍFICOS PARA BOTONES DE ACCIÓN */
/* =========================================== */

.action-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin: 25px 0;
    justify-content: center;
}

.run-button {
    background: linear-gradient(45deg, #00cc66, #00ff88);
    color: white;
    border: none;
    padding: 12px 30px;
    font-size: 1.1em;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 0 20px rgba(0, 255, 136, 0.4);
    text-decoration: none;
    display: inline-block;
}

.run-button:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px rgba(0, 255, 136, 0.7);
    background: linear-gradient(45deg, #00ff88, #33ffaa);
}

.download-button {
    background: linear-gradient(45deg, #3a3aff, #5b5bff);
    color: white;
    border: none;
    padding: 12px 30px;
    font-size: 1.1em;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 0 20px rgba(58, 58, 255, 0.4);
    text-decoration: none;
    display: inline-block;
}

.download-button:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px rgba(58, 58, 255, 0.7);
    background: linear-gradient(45deg, #5b5bff, #7b7bff);
}

/* =========================================== */
/* ESTILOS PARA CREDENCIALES Y NOTAS */
/* =========================================== */

.credentials-box {
    background: rgba(20, 0, 40, 0.8);
    border: 2px solid rgba(160, 0, 255, 0.5);
    border-radius: 10px;
    padding: 20px;
    margin: 25px 0;
    box-shadow: 0 0 15px rgba(160, 0, 255, 0.3);
}

.credential-item {
    display: flex;
    align-items: center;
    margin: 10px 0;
    padding: 8px 15px;
    background: rgba(50, 0, 100, 0.5);
    border-radius: 6px;
}

.credential-label {
    font-weight: bold;
    color: #c77dff;
    min-width: 120px;
}

.credential-value {
    color: white;
    font-family: 'Courier New', monospace;
}

.note {
    background: rgba(255, 193, 7, 0.1);
    border-left: 4px solid #ffc107;
    padding: 15px;
    margin: 20px 0;
    border-radius: 0 8px 8px 0;
}

.note h4 {
    color: #ffc107;
    margin-top: 0;
}

.requirements {
    margin-top: 20px;
    padding: 15px;
    background: rgba(0, 50, 100, 0.3);
    border-radius: 8px;
    border-left: 4px solid #3a3aff;
}

/* =========================================== */
/* ESTILOS PARA BLOQUES DE CÓDIGO */
/* =========================================== */

.code-box {
    position: relative;
    background: rgba(20, 0, 40, 0.9);
    border-radius: 8px;
    padding: 15px;
    margin: 15px 0;
    overflow-x: auto;
    border: 1px solid rgba(200, 100, 255, 0.3);
}

.code-title {
    color: #e0aaff;
    font-size: 0.9em;
    margin-bottom: 10px;
    font-family: monospace;
}

.code-box pre {
    color: #e0aaff;
    margin: 0;
    font-family: 'Courier New', monospace;
    white-space: pre-wrap;
    word-wrap: break-word;
}

/* =========================================== */
/* ESTILOS PARA GALERÍA */
/* =========================================== */

.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 15px;
    margin: 20px 0;
}

.gallery-item {
    background: rgba(50, 0, 100, 0.5);
    padding: 60px 20px;
    text-align: center;
    border-radius: 8px;
    border: 1px solid rgba(200, 100, 255, 0.3);
}

/* =========================================== */
/* ESTILOS PARA GUIAS DE INSTALACIÓN */
/* =========================================== */

.guide-container {
    max-width: 1000px;
    margin: 40px auto;
    text-align: left;
    background: rgba(30, 0, 60, 0.7);
    border-radius: 15px;
    padding: 30px;
    box-shadow: 0 0 25px rgba(160, 0, 255, 0.4);
}

.step {
    margin: 30px 0;
    padding: 20px;
    background: rgba(40, 0, 80, 0.5);
    border-radius: 10px;
    border-left: 4px solid #c77dff;
}

.step-number {
    display: inline-block;
    background: #c77dff;
    color: white;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    text-align: center;
    line-height: 30px;
    font-weight: bold;
    margin-right: 15px;
}

.code-block {
    background: rgba(20, 0, 40, 0.9);
    padding: 15px;
    border-radius: 8px;
    margin: 15px 0;
    overflow-x: auto;
    font-family: 'Courier New', monospace;
    color: #e0aaff;
    border: 1px solid rgba(200, 100, 255, 0.3);
}

.tip {
    background: rgba(0, 100, 100, 0.3);
    border-left: 4px solid #00cccc;
    padding: 15px;
    margin: 15px 0;
    border-radius: 0 8px 8px 0;
}

.warning {
    background: rgba(255, 100, 0, 0.2);
    border-left: 4px solid #ff7700;
    padding: 15px;
    margin: 15px 0;
    border-radius: 0 8px 8px 0;
}

.command {
    background: rgba(0, 0, 0, 0.3);
    padding: 5px 10px;
    border-radius: 4px;
    font-family: monospace;
    color: #00ff88;
}

/* =========================================== */
/* ESTILOS PARA ENLACES DE CONTACTO */
/* =========================================== */

#contact a {
    color: #e0aaff;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.3s ease, text-shadow 0.3s ease;
}

#contact a:hover {
    color: #ffffff;
    text-shadow: 0 0 8px #c77dff, 0 0 12px #9d4edd;
}


/* =========================================== */
/* ESTILOS PARA BOTÓN DE WHATSAPP */
/* =========================================== */

.whatsapp-button-container {
    margin: 25px 0;
    text-align: center;
}

.whatsapp-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: linear-gradient(45deg, #25D366, #128C7E);
    color: white;
    padding: 15px 30px;
    font-size: 1.1em;
    font-weight: bold;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 5px 15px rgba(37, 211, 102, 0.4);
    border: none;
    cursor: pointer;
    animation: pulse 2s infinite;
}

.whatsapp-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.6);
    background: linear-gradient(45deg, #128C7E, #25D366);
}

.whatsapp-button:active {
    transform: translateY(-1px);
}

.whatsapp-button i {
    font-size: 1.3em;
}

@keyframes pulse {
    0% {
        box-shadow: 0 5px 15px rgba(37, 211, 102, 0.4);
    }
    50% {
        box-shadow: 0 5px 25px rgba(37, 211, 102, 0.8);
    }
    100% {
        box-shadow: 0 5px 15px rgba(37, 211, 102, 0.4);
    }
}

/* =========================================== */
/* ESTILOS PARA INFORMACIÓN DE CONTACTO */
/* =========================================== */

.contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 30px 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
}

.contact-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    background: rgba(40, 0, 80, 0.4);
    border-radius: 10px;
    border-left: 4px solid #9d4edd;
    transition: transform 0.3s, background 0.3s;
}

.contact-item:hover {
    transform: translateX(5px);
    background: rgba(50, 0, 100, 0.6);
}

.contact-item i {
    color: #c77dff;
    font-size: 1.2em;
    min-width: 25px;
    text-align: center;
}

.contact-item a {
    color: #e0aaff;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.3s ease, text-shadow 0.3s ease;
    flex: 1;
}

.contact-item a:hover {
    color: #ffffff;
    text-shadow: 0 0 8px #c77dff, 0 0 12px #9d4edd;
}

.contact-item span {
    color: #e0aaff;
    flex: 1;
}

/* =========================================== */
/* ESTILOS PARA NOTA DE CONTACTO */
/* =========================================== */

.contact-note {
    margin-top: 30px;
    padding: 20px;
    background: rgba(30, 0, 60, 0.4);
    border-radius: 10px;
    border: 1px solid rgba(200, 100, 255, 0.2);
    text-align: center;
}

.contact-note p {
    margin: 10px 0;
    color: #d0b3ff;
}

/* =========================================== */
/* RESPONSIVE PARA CONTACTO */
/* =========================================== */

@media (max-width: 768px) {
    .whatsapp-button {
        padding: 12px 25px;
        font-size: 1em;
        
    }
    
    .contact-item {
        padding: 12px 15px;
        font-size: 0.95em;
       
    }
    
    .contact-info {
        gap: 15px;
    }
}

@media (max-width: 480px) {
    .whatsapp-button {
        width: 100%;
        padding: 14px 20px;
        color: white;
    }
    
    .contact-item {
        flex-direction: column;
        text-align: center;
        gap: 10px;
    }
    
    .contact-item i {
        font-size: 1.5em;
    }
    
}

/* Galería Expandible */
.galeria {
    display: flex;
    width: 100%;
    height: 350px;
    gap: 10px;
    overflow: hidden;
    margin-top: 40px;
}

.galeria .imagenes {
    flex: 1;
    height: 100%;
    border-radius: 12px;
    overflow: hidden;
    transition: flex 0.5s ease, filter 0.5s ease;
    cursor: pointer;
    filter: grayscale(40%) brightness(0.9);
}

.galeria .imagenes img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.galeria .imagenes:hover {
    flex: 3;
    filter: grayscale(0%) contrast(110%);
}

.galeria .imagenes:hover img {
    transform: scale(1.1);
}
